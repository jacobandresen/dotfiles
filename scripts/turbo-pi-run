#!/usr/bin/env bash
# Launch pi in offline/standalone mode (skips version checks and network ops).
# Passes all args through, so interactive and headless use both work:
#   turbo-pi-run                          # interactive
#   turbo-pi-run -p "do X"                # one-shot headless
#   turbo-pi-run --continue "keep going"  # resume last session
if ! curl -sf http://localhost:11434/api/tags >/dev/null 2>&1; then
  echo "turbo-pi-run: error: Ollama is not running — start it with 'ollama serve'" >&2
  exit 1
fi
# Keep model loaded between turbo-ralph iterations to avoid reload latency.
exec env PI_OFFLINE=1 OLLAMA_KEEP_ALIVE=30m pi "$@"
